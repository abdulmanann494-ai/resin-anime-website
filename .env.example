# RESIN environment example
PORT=3000
NODE_ENV=production
SESSION_SECRET=replace-with-at-least-32-random-bytes-base64url
AUTH_RATE_LIMIT_MAX=5
WRITE_RATE_LIMIT_MAX=5
GLOBAL_RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12
RESIN_DATA_DIR=/persistent/path/for/resin-data
# Admin seed password — set BEFORE first boot; log in and change it immediately
RESIN_SEED_PASSWORD=replace-with-a-strong-random-password-20plus-chars
